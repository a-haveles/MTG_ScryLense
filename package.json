{
  "name": "app",
  "private": true,
  "scripts": {
    "build": "esbuild app/frontend/application.js --bundle --sourcemap --outdir=app/assets/builds --loader:.js=jsx --loader:.jsx=jsx",
    "build:css": "postcss ./app/assets/stylesheets/application.postcss.css -o ./app/assets/builds/application.css"
  },
  "dependencies": {
    "autoprefixer": "^10.4.21",
    "axios": "^1.9.0",
    "chart.js": "^4.4.9",
    "esbuild": "^0.25.4",
    "postcss": "^8.5.3",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.0",
    "postcss-nesting": "^13.0.1",
    "react": "^19.1.0",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^19.1.0"
  }
}
